---
type Track = {
  artist: string;
  track: string;
};

type Episode = {
  frontmatter: {
    episode: string;
    title: string;
    date: string;
    audio: string;
    tracklist?: Track[];
  };
  compiledContent: () => string | Promise<string>;
};

const modules = import.meta.glob("../content/episodes/*.md", { eager: true });
const episodes = Object.values(modules) as Episode[];

const formatDate = (date: string) =>
  new Date(date).toISOString().slice(0, 10).replaceAll("-", ".");

const formatMonthDay = (date: string) =>
  new Date(date).toISOString().slice(5, 10).replace("-", ".");

const formatYear = (date: string) =>
  new Date(date).getFullYear().toString();

episodes.sort(
  (a, b) =>
    new Date(b.frontmatter.date).getTime() -
    new Date(a.frontmatter.date).getTime()
);

const preparedEpisodes = await Promise.all(
  episodes.map(async (episode) => ({
    episode,
    date: formatDate(episode.frontmatter.date),
    monthDay: formatMonthDay(episode.frontmatter.date),
    year: formatYear(episode.frontmatter.date),
    notes: (await episode.compiledContent()).trim(),
    tracklist: episode.frontmatter.tracklist ?? [],
  }))
);

const latestEpisode = preparedEpisodes[0];
const latestDate = latestEpisode?.date ?? "";
const latestAudio = latestEpisode?.episode.frontmatter.audio ?? "";
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <title>forms of love</title>

  <style>
    :root {
      --bg: #ffffff;
      --panel: #ffffff;
      --text: #111111;
      --muted: #6f6f6f;
      --line: #dddddd;
      --soft: #fafafa;
      --accent: #ff3fa4;
      --mono: "SFMono-Regular", "IBM Plex Mono", "Roboto Mono", Consolas, monospace;
      --sans: Helvetica, Arial, sans-serif;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      font-size: 17px;
      line-height: 1.45;
      letter-spacing: -0.015em;
    }

    .page {
      width: 100%;
      padding: 42px 40px 120px;
    }

    header {
      margin-bottom: 82px;
    }

    .header-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 24px;
      width: 100%;
    }

    .header-main {
      max-width: 520px;
    }

    h1 {
      margin: 0 0 18px;
      font-size: 28px;
      line-height: 1;
      font-weight: 400;
      letter-spacing: -0.065em;
      text-transform: lowercase;
    }

    .home-link {
      color: inherit;
      text-decoration: none;
      transition: color 0.12s ease;
    }

    .home-link:hover {
      color: var(--accent);
    }

    .intro {
      max-width: 500px;
      color: var(--muted);
      font-family: var(--mono);
      font-size: 15px;
      line-height: 1.5;
      letter-spacing: -0.02em;
    }

    .contact-link {
      color: var(--muted);
      font-family: var(--mono);
      font-size: 14px;
      letter-spacing: -0.02em;
      text-decoration: none;
      transition: color 0.12s ease;
    }

    .contact-link:hover {
      color: var(--accent);
    }

    .archive {
      width: 100%;
    }

    .year-divider {
      padding: 0 0 18px;
      border-bottom: 1px solid var(--text);
      color: var(--muted);
      font-family: var(--mono);
      font-size: 15px;
      letter-spacing: 0.06em;
    }

    .episode {
      border-bottom: 1px solid var(--line);
      transition: background 0.12s ease;
    }

    .episode.open {
      background: var(--soft);
    }

    .episode-row {
      width: 100%;
      display: grid;
      grid-template-columns: 46px 1fr;
      align-items: center;
      padding: 18px 0;
    }

    .episode-play {
      border: 0;
      background: transparent;
      color: var(--muted);
      font-family: var(--sans);
      font-size: 24px;
      line-height: 1;
      padding: 0;
      cursor: pointer;
      text-align: left;
      transition: color 0.12s ease;
    }

    .episode-play:hover,
    .episode-play.active {
      color: var(--accent);
    }

    .episode-date-button {
      border: 0;
      background: transparent;
      color: inherit;
      padding: 0;
      text-align: left;
      cursor: pointer;
    }

    .episode-date {
      font-size: 28px;
      line-height: 1;
      font-weight: 400;
      letter-spacing: -0.05em;
      transition: color 0.12s ease;
    }

    .episode-date-button:hover .episode-date {
      color: var(--accent);
    }

    .episode-details {
      display: none;
      max-width: 780px;
      padding: 8px 0 42px 46px;
    }

    .episode.open .episode-details {
      display: block;
    }

    .section-label {
      margin-bottom: 11px;
      color: var(--muted);
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      opacity: 0.55;
    }

    .notes {
      max-width: 720px;
      margin-bottom: 34px;
      color: #1c1c1c;
      font-family: var(--mono);
      font-size: 15px;
      line-height: 1.55;
      letter-spacing: -0.015em;
    }

    .notes p {
      margin-top: 0;
    }

    .tracklist {
      font-family: var(--mono);
      font-size: 15px;
      line-height: 1.55;
      letter-spacing: -0.015em;
    }

    .track {
      display: flex;
      gap: 20px;
      margin-bottom: 6px;
    }

    .player {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 50;
      display: flex;
      align-items: center;
      gap: 18px;
      padding: 10px 40px;
      background: var(--panel);
      border-top: 1px solid var(--line);
    }

    .player-meta {
      min-width: 260px;
      flex-shrink: 0;
    }

    .player-label {
      margin-bottom: 0;
      color: var(--muted);
      font-family: var(--mono);
      font-size: 13px;
      text-transform: lowercase;
    }

    .player-title {
      overflow: hidden;
      font-size: 15px;
      line-height: 1.25;
      letter-spacing: -0.03em;
      white-space: nowrap;
      text-overflow: ellipsis;
    }

    .player-button {
      flex-shrink: 0;
      border: 0;
      background: transparent;
      color: var(--text);
      font-family: var(--sans);
      font-size: 24px;
      line-height: 1;
      padding: 0;
      cursor: pointer;
      text-align: left;
      transition: color 0.12s ease;
    }

    .player-button:hover {
      color: var(--accent);
    }

    .player-time {
      flex-shrink: 0;
      color: var(--muted);
      font-family: var(--mono);
      font-size: 14px;
      white-space: nowrap;
    }

    .player-progress {
      flex: 1;
      width: 100%;
      height: 2px;
      margin: 0;
      appearance: none;
      background: var(--line);
      cursor: pointer;
    }

    .player-progress::-webkit-slider-thumb {
      width: 9px;
      height: 9px;
      appearance: none;
      background: var(--text);
      border-radius: 50%;
    }

    .player-progress::-moz-range-thumb {
      width: 9px;
      height: 9px;
      background: var(--text);
      border: 0;
      border-radius: 50%;
    }

    .player-progress:hover::-webkit-slider-thumb {
      background: var(--accent);
    }

    @media (max-width: 850px) {
      .page {
        padding: 30px 18px 165px;
      }

      header {
        margin-bottom: 64px;
      }

      .header-top {
        flex-direction: column;
        gap: 18px;
      }

      .contact-link {
        font-size: 13px;
      }

      .episode-row {
        grid-template-columns: 40px 1fr;
      }

      .episode-details {
        padding-left: 40px;
      }

      .player {
        display: grid;
        grid-template-columns: 32px auto 1fr;
        gap: 8px 14px;
        align-items: center;
        padding: 10px 18px 12px;
      }

      .player-meta {
        grid-column: 1 / -1;
        min-width: 0;
      }

      .player-button {
        grid-column: 1;
        grid-row: 2;
      }

      .player-time {
        grid-column: 2;
        grid-row: 2;
      }

      .player-progress {
        grid-column: 3;
        grid-row: 2;
      }

      .player-title {
        white-space: normal;
      }
    }
  </style>
</head>

<body>
  <main class="page">
    <header>
      <div class="header-top">
        <div class="header-main">
          <h1>
            <a class="home-link" href="/">forms of love</a>
          </h1>

          <div class="intro">
            sharing the records, sounds, and discoveries that continue to reshape my listening. airing on cjam 99.1 fm since 2022.
          </div>
        </div>

        <a class="contact-link" href="mailto:hello@formsoflove.com">
          hello@formsoflove.com
        </a>
      </div>
    </header>

    <section class="archive">
      {
        preparedEpisodes.map((item, index) => {
          const previousYear = index > 0 ? preparedEpisodes[index - 1].year : null;
          const showYear = item.year !== previousYear;

          return (
            <>
              {showYear && <div class="year-divider">{item.year}</div>}

              <article class="episode">
                <div class="episode-row">
                  <button
                    class="episode-play"
                    type="button"
                    aria-label="play broadcast"
                    data-audio={item.episode.frontmatter.audio}
                    data-date={item.date}
                  >
                    ▷
                  </button>

                  <button class="episode-date-button" type="button" data-toggle>
                    <div class="episode-date">{item.monthDay}</div>
                  </button>
                </div>

                <div class="episode-details">
                  {item.notes && (
                    <div class="notes" set:html={item.notes} />
                  )}

                  {item.tracklist.length > 0 && (
                    <div class="tracklist">
                      <div class="section-label">tracklist</div>

                      {item.tracklist.map((track) => (
                        <div class="track">
                          {track.artist} — {track.track}
                        </div>
                      ))}
                    </div>
                  )}
                </div>
              </article>
            </>
          );
        })
      }
    </section>
  </main>

  <aside class="player">
    <div class="player-meta">
      <div class="player-label">now playing</div>
      <div class="player-title" id="playerTitle">
        forms of love — {latestDate}
      </div>
    </div>

    <button class="player-button" id="playerButton" type="button">▷</button>

    <div class="player-time">
      <span id="currentTime">0:00</span>
      <span>/</span>
      <span id="duration">0:00</span>
    </div>

    <input
      class="player-progress"
      id="playerProgress"
      type="range"
      min="0"
      max="100"
      value="0"
    />

    <audio id="audioPlayer" preload="none" src={latestAudio}></audio>
  </aside>

  <script>
    const episodes = document.querySelectorAll(".episode");
    const episodePlayButtons = document.querySelectorAll(".episode-play");

    const audioPlayer = document.getElementById("audioPlayer") as HTMLAudioElement | null;
    const playerTitle = document.getElementById("playerTitle") as HTMLElement | null;
    const playerButton = document.getElementById("playerButton") as HTMLButtonElement | null;
    const playerProgress = document.getElementById("playerProgress") as HTMLInputElement | null;
    const currentTimeEl = document.getElementById("currentTime") as HTMLElement | null;
    const durationEl = document.getElementById("duration") as HTMLElement | null;

    let currentEpisodeButton: Element | null = null;

    const formatTime = (seconds: number) => {
      if (!Number.isFinite(seconds)) return "0:00";

      const minutes = Math.floor(seconds / 60);
      const remainingSeconds = Math.floor(seconds % 60)
        .toString()
        .padStart(2, "0");

      return `${minutes}:${remainingSeconds}`;
    };

    const resetEpisodeButtons = () => {
      episodePlayButtons.forEach((button) => {
        button.textContent = "▷";
        button.classList.remove("active");
      });
    };

    const setPlayingButton = () => {
      resetEpisodeButtons();

      if (!currentEpisodeButton || !audioPlayer || audioPlayer.paused) return;

      currentEpisodeButton.textContent = "Ⅱ";
      currentEpisodeButton.classList.add("active");
    };

    episodes.forEach((episode) => {
      const toggles = episode.querySelectorAll("[data-toggle]");

      toggles.forEach((toggle) => {
        toggle.addEventListener("click", () => {
          episode.classList.toggle("open");
        });
      });
    });

    episodePlayButtons.forEach((button) => {
      button.addEventListener("click", (event) => {
        event.stopPropagation();

        const audio = button.getAttribute("data-audio") || "";
        const date = button.getAttribute("data-date") || "";

        if (!audioPlayer || !audio) return;

        if (currentEpisodeButton === button && !audioPlayer.paused) {
          audioPlayer.pause();
          return;
        }

        if (currentEpisodeButton === button && audioPlayer.paused) {
          audioPlayer.play();
          return;
        }

        currentEpisodeButton = button;
        audioPlayer.src = audio;
        audioPlayer.play();

        if (playerTitle) {
          playerTitle.textContent = `forms of love — ${date}`;
        }
      });
    });

    playerButton?.addEventListener("click", () => {
      if (!audioPlayer || !audioPlayer.src) return;

      if (audioPlayer.paused) {
        audioPlayer.play();
      } else {
        audioPlayer.pause();
      }
    });

    audioPlayer?.addEventListener("play", () => {
      if (playerButton) playerButton.textContent = "Ⅱ";
      setPlayingButton();
    });

    audioPlayer?.addEventListener("pause", () => {
      if (playerButton) playerButton.textContent = "▷";
      setPlayingButton();
    });

    audioPlayer?.addEventListener("loadedmetadata", () => {
      if (durationEl && audioPlayer) {
        durationEl.textContent = formatTime(audioPlayer.duration);
      }
    });

    audioPlayer?.addEventListener("timeupdate", () => {
      if (!audioPlayer || !playerProgress) return;

      if (currentTimeEl) {
        currentTimeEl.textContent = formatTime(audioPlayer.currentTime);
      }

      if (audioPlayer.duration) {
        playerProgress.value = String(
          (audioPlayer.currentTime / audioPlayer.duration) * 100
        );
      }
    });

    playerProgress?.addEventListener("input", () => {
      if (!audioPlayer || !audioPlayer.duration) return;

      audioPlayer.currentTime =
        (Number(playerProgress.value) / 100) * audioPlayer.duration;
    });
  </script>
</body>
</html>